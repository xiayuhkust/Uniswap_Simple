{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext"],
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "jsxImportSource": "react",
    "types": ["vite/client", "node", "react", "react-dom", "@web3-react/core", "@types/react", "@types/react-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ark-ui/react/*": ["./node_modules/@chakra-ui/react/node_modules/@ark-ui/react/dist/components/*"],
      "@chakra-ui/*": ["./node_modules/@chakra-ui/*/dist"]
    },
    "downlevelIteration": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src", "src/types"]
}
